{
  "inputs": [
    {
      "id": "ado_org",
      "type": "promptString",
      "description": "Azure DevOps organization name (e.g. 'IdentityDivision')",
      "default": "IdentityDivision"
    }
  ],
  "servers": {
    // MCP Server Configuration for Android Auth Client
    // Docs: https://code.visualstudio.com/docs/copilot/chat/mcp-servers
    //
    // Bluebird MCP servers (bluebirdrepos & bluebirdrepos2) are automatically
    // provided by the Bluebird extension (bluebird-ai-labs.bluebird-vscode).
    // No configuration needed here — just install the extension.
    // See .vscode/extensions.json for the recommended extension.

    "ado": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "${input:ado_org}",
        "-d",
        "core",
        "work",
        "work-items",
        "repositories",
        "pipelines"
      ]
    },

    "workiq": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@microsoft/workiq", "mcp"],
      "tools": ["*"]
    },

    "azure-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"],
      "tools": ["*"]
    },

    "android-dri-search": {
      "type": "http",
      "url": "https://android-dri-mcp.proudbeach-7e7ce77d.eastus.azurecontainerapps.io/mcp"
    }
  }
}
